{
  "title": "Infrastructure Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "Container CPU Usage",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "rate(container_cpu_usage_seconds_total{name!=\"\"}[1m])", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container Memory Usage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "container_memory_usage_bytes{name!=\"\"}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Backend HTTP Request Duration (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Node CPU / Load",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "node_load1", "refId": "A" }
      ]
    }
  ]
}
